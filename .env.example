GOOGLE_CHAT_SUBSCRIPTION=projects/YOUR_PROJECT/subscriptions/YOUR_SUB
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-sa-key.json

# Optional: emoji reactions on tool calls (requires Domain-Wide Delegation)
# Leave blank or remove to disable reactions entirely.
# See README for DWD setup instructions.
# REACTION_USER_EMAIL=you@yourdomain.com

# Optional: 1Password service account token for secret retrieval
# Create at: https://my.1password.com/developer-tools/infrastructure-secrets/serviceaccount
# OP_SERVICE_ACCOUNT_TOKEN=ops_...

# Optional: Claude response timeout (default: 600000 = 10 minutes)
# CLAUDE_TIMEOUT_MS=1200000

# Optional: periodic heartbeat checks (omit HEARTBEAT_SPACE to disable entirely)
# HEARTBEAT_SPACE=spaces/YOUR_SPACE_ID
# HEARTBEAT_INTERVAL_MINUTES=30
# HEARTBEAT_ACTIVE_HOURS=7-23
# HEARTBEAT_TIMEZONE=America/Denver
